{
  "title": "fbufler",
  "uid": "fbufler-main",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "30s",
  "time": { "from": "now-1h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "title": "Active Visitors",
      "type": "stat",
      "gridPos": { "x": 0, "y": 0, "w": 4, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "options": { "colorMode": "background", "graphMode": "none", "textMode": "auto" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "steps": [
            { "color": "green", "value": null },
            { "color": "yellow", "value": 5 },
            { "color": "red", "value": 20 }
          ]}
        }
      },
      "targets": [{ "expr": "active_visitors", "legendFormat": "visitors" }]
    },
    {
      "id": 2,
      "title": "Requests / min",
      "type": "stat",
      "gridPos": { "x": 4, "y": 0, "w": 4, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "options": { "colorMode": "background", "graphMode": "area" },
      "fieldConfig": { "defaults": { "unit": "reqpm", "color": { "mode": "thresholds" }, "thresholds": { "steps": [{ "color": "green", "value": null }] } } },
      "targets": [{ "expr": "round(sum(rate(http_requests_total[1m])) * 60, 0.01)", "legendFormat": "req/min" }]
    },
    {
      "id": 3,
      "title": "404 Errors (1h)",
      "type": "stat",
      "gridPos": { "x": 8, "y": 0, "w": 4, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "options": { "colorMode": "background", "graphMode": "none" },
      "fieldConfig": { "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "steps": [{ "color": "green", "value": null }, { "color": "red", "value": 1 }] } } },
      "targets": [{ "expr": "sum(increase(http_requests_total{status=\"404\"}[1h])) or vector(0)", "legendFormat": "404s" }]
    },
    {
      "id": 4,
      "title": "P95 Response Time",
      "type": "stat",
      "gridPos": { "x": 12, "y": 0, "w": 4, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "options": { "colorMode": "background", "graphMode": "none" },
      "fieldConfig": { "defaults": { "unit": "s", "color": { "mode": "thresholds" }, "thresholds": { "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 0.5 }, { "color": "red", "value": 1 }] } } },
      "targets": [{ "expr": "histogram_quantile(0.95, sum(rate(http_request_duration_seconds_bucket[5m])) by (le))", "legendFormat": "p95" }]
    },
    {
      "id": 5,
      "title": "Heap Used",
      "type": "stat",
      "gridPos": { "x": 16, "y": 0, "w": 4, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "options": { "colorMode": "background", "graphMode": "none" },
      "fieldConfig": { "defaults": { "unit": "bytes", "color": { "mode": "thresholds" }, "thresholds": { "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 200000000 }, { "color": "red", "value": 400000000 }] } } },
      "targets": [{ "expr": "nodejs_heap_size_used_bytes", "legendFormat": "heap used" }]
    },
    {
      "id": 6,
      "title": "Event Loop Lag",
      "type": "stat",
      "gridPos": { "x": 20, "y": 0, "w": 4, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "options": { "colorMode": "background", "graphMode": "none" },
      "fieldConfig": { "defaults": { "unit": "s", "color": { "mode": "thresholds" }, "thresholds": { "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 0.1 }, { "color": "red", "value": 0.5 }] } } },
      "targets": [{ "expr": "nodejs_eventloop_lag_seconds", "legendFormat": "lag" }]
    },
    {
      "id": 7,
      "title": "Requests over Time",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 4, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "reqps", "color": { "mode": "palette-classic" } } },
      "targets": [
        { "expr": "sum(rate(page_views_total[5m])) by (page)", "legendFormat": "{{page}}" }
      ]
    },
    {
      "id": 8,
      "title": "Top Pages (24h)",
      "type": "table",
      "gridPos": { "x": 12, "y": 4, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "options": { "sortBy": [{ "displayName": "Value", "desc": true }] },
      "targets": [{ "expr": "sort_desc(sum by (page) (increase(page_views_total[24h])))", "legendFormat": "{{page}}", "instant": true, "format": "table" }]
    },
    {
      "id": 9,
      "title": "Response Status Breakdown",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 12, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "reqps", "color": { "mode": "palette-classic" } } },
      "targets": [
        { "expr": "sum(rate(http_requests_total[1m])) by (status)", "legendFormat": "{{status}}" }
      ]
    },
    {
      "id": 10,
      "title": "404 Routes (24h)",
      "type": "table",
      "gridPos": { "x": 12, "y": 12, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "options": { "sortBy": [{ "displayName": "Value", "desc": true }] },
      "targets": [{ "expr": "sort_desc(sum by (route) (increase(http_requests_total{status=\"404\"}[24h])))", "legendFormat": "{{route}}", "instant": true, "format": "table" }]
    },
    {
      "id": 11,
      "title": "Node.js Heap",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 20, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "bytes", "color": { "mode": "palette-classic" } } },
      "targets": [
        { "expr": "nodejs_heap_size_used_bytes", "legendFormat": "used" },
        { "expr": "nodejs_heap_size_total_bytes", "legendFormat": "total" }
      ]
    },
    {
      "id": 12,
      "title": "Event Loop Lag over Time",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 20, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "s", "color": { "mode": "palette-classic" } } },
      "targets": [{ "expr": "nodejs_eventloop_lag_seconds", "legendFormat": "lag" }]
    },
    {
      "id": 13,
      "title": "VPS CPU Usage",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 28, "w": 8, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "percentunit", "min": 0, "max": 1, "color": { "mode": "palette-classic" } } },
      "targets": [{ "expr": "1 - avg(rate(node_cpu_seconds_total{mode=\"idle\"}[1m]))", "legendFormat": "cpu" }]
    },
    {
      "id": 14,
      "title": "VPS Memory",
      "type": "timeseries",
      "gridPos": { "x": 8, "y": 28, "w": 8, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "bytes", "color": { "mode": "palette-classic" } } },
      "targets": [
        { "expr": "node_memory_MemTotal_bytes - node_memory_MemAvailable_bytes", "legendFormat": "used" },
        { "expr": "node_memory_MemTotal_bytes", "legendFormat": "total" }
      ]
    },
    {
      "id": 15,
      "title": "VPS Disk Usage",
      "type": "gauge",
      "gridPos": { "x": 16, "y": 28, "w": 8, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "options": { "minVizWidth": 75, "reduceOptions": { "calcs": ["lastNotNull"] } },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0, "max": 1,
          "color": { "mode": "thresholds" },
          "thresholds": { "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 0.7 }, { "color": "red", "value": 0.9 }] }
        }
      },
      "targets": [{ "expr": "1 - (node_filesystem_avail_bytes{mountpoint=\"/\",fstype!=\"tmpfs\"} / node_filesystem_size_bytes{mountpoint=\"/\",fstype!=\"tmpfs\"})", "legendFormat": "disk /" }]
    },
    {
      "id": 16,
      "title": "VPS Network",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 36, "w": 24, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "Bps", "color": { "mode": "palette-classic" } } },
      "targets": [
        { "expr": "rate(node_network_receive_bytes_total{device!=\"lo\"}[1m])", "legendFormat": "rx {{device}}" },
        { "expr": "rate(node_network_transmit_bytes_total{device!=\"lo\"}[1m])", "legendFormat": "tx {{device}}" }
      ]
    }
  ]
}
